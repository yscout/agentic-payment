# === Agent Configuration ===

# Private key for the agent wallet (hex, with 0x prefix)
# Leave empty to auto-generate a new wallet each run
AGENT_PRIVATE_KEY=

# === Network ===

# Base Sepolia RPC URL
RPC_URL=https://sepolia.base.org

# Chain identifier for x402 (Base Sepolia)
X402_NETWORK=eip155:84532

# === Server ===

# Data provider server URL
SERVER_URL=http://localhost:4021

# Server listen port
PORT=4021

# Provider wallet that receives x402 USDC payments
PROVIDER_WALLET_ADDRESS=

# Private key for the DataMarketplace owner/server wallet that records provenance
PROVIDER_PRIVATE_KEY=

# x402 facilitator used by the provider server
X402_FACILITATOR_URL=https://x402.org/facilitator

# Set false only for local endpoint testing without payment gating
ENABLE_X402=true

# === Contracts (filled after Person A deploys) ===

# DataMarketplace contract address on Base Sepolia
DATA_MARKETPLACE_ADDRESS=

# === Agent Behavior ===

# How many seconds to wait between queries
QUERY_INTERVAL_SECONDS=3

# Maximum number of queries before stopping (0 = unlimited, stop only on balance)
MAX_QUERIES=0

# Initial USDC amount to deposit (in human-readable units, e.g., 0.10)
DEPOSIT_AMOUNT=0.10
